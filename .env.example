# ========== CORE ==========
NODE_ENV=development
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
MAIN_DOMAIN=

# ========== API ==========
NEXT_PUBLIC_API_URL=
ENCRYPTED_KEY=

# ========== SEO ==========
SITENAME='THE SALTANAT'
SITENAMEDESCRIPTION=''
AUTHOR='The Saltanat'
NEXT_PUBLIC_DEFAULT_OG_IMAGE=
NEXT_PUBLIC_META_KEYWORDS=

# ========== CDN / ASSETS ==========
NEXT_PUBLIC_CDN_URL=
NEXT_PUBLIC_IMAGE_DOMAIN=
NEXT_PUBLIC_MAIN_LOGO=/images/static/logo.svg
NEXT_PUBLIC_MAIN_FAVICON=/images/static/favicon-16x16.png

# ========== ANALYTICS ==========
NEXT_PUBLIC_GOOGLE_ANALYTICS=
NEXT_PUBLIC_GOOGLE_TAG_MANAGER=
NEXT_PUBLIC_FEATURE_FLAG=true
NEXT_PUBLIC_GOOGLE_VARIFICATION=
NEXT_PUBLIC_FACEBOOK_VARIFICATION=

# ========== SECURITY / AUTH (if applicable) ==========
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=

# ========== FLAGS ==========
NEXT_PUBLIC_ENABLE_DEBUG=false
NEXT_PUBLIC_MAINTENANCE_MODE=false
